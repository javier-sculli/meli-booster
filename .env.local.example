# MercadoLibre App credentials
# Obtené estas credenciales en: https://developers.mercadolibre.com.ar/devcenter
MELI_APP_ID=your_app_id_here
MELI_APP_SECRET=your_app_secret_here

# URL de callback (debe coincidir exactamente con la configurada en tu app de MeLi)
# En desarrollo usa: http://localhost:3000/api/auth/callback
# En producción reemplazá con tu dominio
MELI_REDIRECT_URI=https://localhost:3000/api/auth/callback
